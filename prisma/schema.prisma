generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  ADMIN
  GERENTE
  VENDEDOR
  OPERADOR

  @@map("crm_user_role")
}

enum TipoCredito {
  ETIQUETA
  VALOR

  @@map("crm_tipo_credito")
}

enum OperacaoCredito {
  CREDITO
  DEBITO

  @@map("crm_operacao_credito")
}

enum ModuloStatus {
  ORCAMENTO
  PEDIDO

  @@map("crm_modulo_status")
}

enum StatusSugestao {
  PENDENTE
  APROVADA
  REJEITADA
  APLICADA

  @@map("crm_status_sugestao")
}

// ─────────────────────────────────────────────
// EMPRESA
// ─────────────────────────────────────────────

model Empresa {
  id                Int      @id @default(autoincrement())
  razaoSocial       String
  nomeFantasia      String
  cnpj              String   @unique
  inscricaoEstadual String?
  telefone          String
  email             String
  cep               String
  logradouro        String
  numero            String
  complemento       String?
  bairro            String
  cidade            String
  estado            String
  corSidebar        String?
  corPrimaria       String?
  logoUrl           String?
  criadoEm          DateTime @default(now())
  updatedAt         DateTime @updatedAt

  users                User[]
  vendedores           Vendedor[]
  clientes             Cliente[]
  produtos             Produto[]
  categorias           Categoria[]
  fornecedores         Fornecedor[]
  tabelasPreco         TabelaPreco[]
  orcamentos           Orcamento[]
  pedidos              Pedido[]
  movimentacoesCredito MovimentacaoCredito[]
  status               Status[]
  formasPagamento      FormaPagamento[]
  aiConfig             AIConfig?
  aiAprendizados       AIAprendizado[]
  aiSugestoes          AISugestao[]
  aiUsage              AIUsage[]
  
  // Integrações
  apiToken             String?       @unique
  origensLead          OrigemLead[]
  statusFunil          FunilStatus[]
  leads                Lead[]

  // Compras
  compraConfig         CompraConfigEmpresa?
  fornecedorImportConfigs FornecedorImportConfig[]
  fornecedorImportacoes   FornecedorImportacao[]
  fornecedorProdutoMaps   FornecedorProdutoMap[]
  fornecedorPrecosAtuais  FornecedorPrecoAtual[]
  fornecedorPrecosHistorico FornecedorPrecoHistorico[]
  sugestoesCompra        SugestaoCompra[]
  cotacoesCompra         CotacaoCompra[]
  pedidosCompra          PedidoCompra[]
  compraAuditorias       CompraAuditoria[]

  @@map("crm_empresas")
}

// ─────────────────────────────────────────────
// USUÁRIOS E VENDEDORES
// ─────────────────────────────────────────────

model User {
  id         Int      @id @default(autoincrement())
  empresaId  Int
  nome       String
  email      String
  senha      String
  role       UserRole @default(OPERADOR)
  ativo      Boolean  @default(true)
  criadoEm   DateTime @default(now())
  updatedAt  DateTime @updatedAt
  vendedorId Int?

  empresa      Empresa         @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  vendedor     Vendedor?       @relation(fields: [vendedorId], references: [id], onDelete: SetNull)
  chatMessages AIChatMessage[]
  compraAuditorias CompraAuditoria[]

  @@unique([empresaId, email])
  @@index([empresaId])
  @@index([role])
  @@index([vendedorId])
  @@index([ativo])
  @@map("crm_users")
}

model Vendedor {
  id        Int      @id @default(autoincrement())
  empresaId Int
  nome      String
  email     String
  telefone  String
  comissao  Float    @default(0)
  regiao    String?
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())
  updatedAt DateTime @updatedAt

  empresa    Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  users      User[]
  orcamentos Orcamento[]
  pedidos    Pedido[]
  leads      Lead[]

  @@unique([empresaId, email])
  @@index([empresaId])
  @@index([nome])
  @@index([ativo])
  @@map("crm_vendedores")
}

// ─────────────────────────────────────────────
// CLIENTES
// ─────────────────────────────────────────────

model Cliente {
  id                    Int       @id @default(autoincrement())
  empresaId             Int
  razaoSocial           String
  nomeFantasia          String?
  cnpj                  String
  ie                    String?
  email                 String?
  telefone              String
  // Endereço estruturado (removido campo "endereco" texto livre)
  logradouro            String?
  numeroEnd             String?
  complemento           String?
  bairro                String?
  cep                   String
  cidade                String
  estado                String
  observacoes           String?
  ativo                 Boolean   @default(true)
  ultimaCompra          DateTime?
  criadoEm              DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  compradorNome         String?
  compradorTelefone     String?
  saldoCreditoEtiquetas Int       @default(0)
  saldoCreditoProdutos  Int       @default(0)
  saldoCreditoValor     Float     @default(0)
  tabelaPrecoId         Int?

  empresa              Empresa                @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  tabelaPreco          TabelaPreco?           @relation(fields: [tabelaPrecoId], references: [id])
  produtosExclusivos   ClienteProduto[]
  itensExclusivos      ItemExclusivoCliente[]
  movimentacoesCredito MovimentacaoCredito[]
  orcamentos           Orcamento[]
  pedidos              Pedido[]
  aiSugestoes          AISugestao[]
  leads                Lead[]

  @@unique([empresaId, cnpj])
  @@index([empresaId])
  @@index([razaoSocial])
  @@index([cnpj])
  @@index([cidade])
  @@index([ativo])
  @@index([ultimaCompra])
  @@index([criadoEm])
  @@map("crm_clientes")
}

// ─────────────────────────────────────────────
// CATÁLOGO
// ─────────────────────────────────────────────

model Categoria {
  id        Int      @id @default(autoincrement())
  empresaId Int
  nome      String
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())
  updatedAt DateTime @updatedAt

  empresa  Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  produtos Produto[]

  @@unique([empresaId, nome])
  @@index([empresaId])
  @@index([ativo])
  @@map("crm_categorias")
}

model Fornecedor {
  id          Int      @id @default(autoincrement())
  empresaId   Int
  razaoSocial String
  cnpj        String?
  telefone    String?
  email       String?
  ativo       Boolean  @default(true)
  criadoEm    DateTime @default(now())
  updatedAt   DateTime @updatedAt

  empresa  Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  produtos Produto[]
  importConfig       FornecedorImportConfig?
  importacoes        FornecedorImportacao[]
  produtoMaps        FornecedorProdutoMap[]
  precosAtuais       FornecedorPrecoAtual[]
  cotacoesFornecedor CotacaoCompraFornecedor[]
  cotacaoEscolhas    CotacaoCompraEscolha[]
  pedidosCompra      PedidoCompra[]

  @@index([empresaId])
  @@index([ativo])
  @@map("crm_fornecedores")
}

model Produto {
  id            Int      @id @default(autoincrement())
  empresaId     Int
  codigo        String
  nome          String
  descricao     String?
  fornecedorId  Int?
  ean           String?
  estoque       Float    @default(0)
  precoBase     Float    @default(0)
  categoriaId   Int?
  unidadePadrao String   @default("UN")
  ativo         Boolean  @default(true)
  criadoEm      DateTime @default(now())
  updatedAt     DateTime @updatedAt

  empresa              Empresa               @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  fornecedor           Fornecedor?           @relation(fields: [fornecedorId], references: [id], onDelete: SetNull)
  categoria            Categoria?            @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  clientesAutorizados  ClienteProduto[]
  itensOrcamento       ItemOrcamento[]
  itensPedido          ItemPedido[]
  tabelasPreco         TabelaPrecoItem[]
  movimentacoesEstoque MovimentacaoEstoque[]
  importacaoLinhas     FornecedorImportacaoLinha[]
  fornecedorMaps       FornecedorProdutoMap[]
  precosAtuais         FornecedorPrecoAtual[]
  precosHistorico      FornecedorPrecoHistorico[]
  sugestaoItens        SugestaoCompraItem[]
  cotacaoItens         CotacaoCompraItem[]
  itensPedidoCompra    ItemPedidoCompra[]

  @@unique([empresaId, codigo])
  @@index([empresaId])
  @@index([nome])
  @@index([codigo])
  @@index([ativo])
  @@index([criadoEm])
  @@map("crm_produtos")
}

// Rastreabilidade de estoque
model MovimentacaoEstoque {
  id            Int      @id @default(autoincrement())
  empresaId     Int
  produtoId     Int
  tipo          String // ENTRADA | SAIDA | AJUSTE
  quantidade    Float
  estoqueAntes  Float
  estoqueDepois Float
  descricao     String?
  pedidoId      Int?
  criadoEm      DateTime @default(now())

  produto Produto @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@index([produtoId])
  @@index([empresaId])
  @@index([criadoEm])
  @@map("crm_movimentacoes_estoque")
}

// ─────────────────────────────────────────────
// TABELAS DE PREÇO
// ─────────────────────────────────────────────

model TabelaPreco {
  id        Int      @id @default(autoincrement())
  empresaId Int
  nome      String
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())
  updatedAt DateTime @updatedAt

  empresa  Empresa           @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  itens    TabelaPrecoItem[]
  clientes Cliente[]
  orcamentos Orcamento[]

  @@unique([empresaId, nome])
  @@index([empresaId])
  @@index([ativo])
  @@map("crm_tabelas_preco")
}

model TabelaPrecoItem {
  id            Int   @id @default(autoincrement())
  tabelaPrecoId Int
  produtoId     Int
  preco         Float

  tabelaPreco TabelaPreco @relation(fields: [tabelaPrecoId], references: [id], onDelete: Cascade)
  produto     Produto     @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@unique([tabelaPrecoId, produtoId])
  @@index([tabelaPrecoId])
  @@index([produtoId])
  @@map("crm_tabelas_preco_itens")
}

model ClienteProduto {
  clienteId Int
  produtoId Int
  preco     Float?

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  produto Produto @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@id([clienteId, produtoId])
  @@map("crm_clientes_produtos")
}

// ─────────────────────────────────────────────
// STATUS / FORMA DE PAGAMENTO
// ─────────────────────────────────────────────

model Status {
  id        Int          @id @default(autoincrement())
  empresaId Int
  nome      String
  ordem     Int
  modulo    ModuloStatus
  cor       String
  ativo     Boolean      @default(true)
  criadoEm  DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  empresa    Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  orcamentos Orcamento[]
  pedidos    Pedido[]

  @@unique([empresaId, modulo, ordem])
  @@index([empresaId])
  @@index([modulo, ordem])
  @@index([ativo])
  @@map("crm_status")
}

model FormaPagamento {
  id                 Int      @id @default(autoincrement())
  empresaId          Int
  nome               String
  quantidadeParcelas Int      @default(1)
  ativo              Boolean  @default(true)
  criadoEm           DateTime @default(now())
  updatedAt          DateTime @updatedAt

  empresa    Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  orcamentos Orcamento[]
  pedidos    Pedido[]

  @@unique([empresaId, nome])
  @@index([empresaId])
  @@index([ativo])
  @@map("crm_formas_pagamento")
}

// ─────────────────────────────────────────────
// ORÇAMENTOS
// ─────────────────────────────────────────────

model Orcamento {
  id               Int       @id @default(autoincrement())
  empresaId        Int
  numero           String
  clienteId        Int
  vendedorId       Int
  statusId         Int
  formaPagamentoId Int?
  tabelaPrecoId    Int?
  observacoes      String?
  totalGeral       Float
  descontoCredito  Float     @default(0)
  valorFrete       Float     @default(0)
  tipoFrete        String?
  prazoEntrega     DateTime?
  ocCliente        String?
  ativo            Boolean   @default(true)
  criadoEm         DateTime  @default(now())
  atualizadoEm     DateTime  @updatedAt

  empresa        Empresa         @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente        Cliente         @relation(fields: [clienteId], references: [id])
  vendedor       Vendedor        @relation(fields: [vendedorId], references: [id])
  status         Status          @relation(fields: [statusId], references: [id])
  formaPagamento FormaPagamento? @relation(fields: [formaPagamentoId], references: [id])
  tabelaPreco    TabelaPreco?    @relation(fields: [tabelaPrecoId], references: [id])
  itens          ItemOrcamento[]
  pedidos        Pedido[]

  @@unique([empresaId, numero])
  @@index([empresaId])
  @@index([clienteId])
  @@index([vendedorId])
  @@index([statusId])
  @@index([criadoEm])
  @@index([ativo])
  @@index([ocCliente])
  @@map("crm_orcamentos")
}

model ItemOrcamento {
  id                Int     @id @default(autoincrement())
  orcamentoId       Int
  produtoId         Int?
  descricao         String
  quantidade        Float // Float para suportar frações
  unidade           String
  precoUnitario     Float
  desconto          Float   @default(0)
  total             Float
  observacao        String?
  quantidadeCredito Float   @default(0)

  produto   Produto?  @relation(fields: [produtoId], references: [id], onDelete: SetNull)
  orcamento Orcamento @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)

  @@index([orcamentoId])
  @@index([produtoId])
  @@map("crm_itens_orcamento")
}

// ─────────────────────────────────────────────
// PEDIDOS
// ─────────────────────────────────────────────

model Pedido {
  id                     Int       @id @default(autoincrement())
  empresaId              Int
  numero                 String
  orcamentoId            Int?
  clienteId              Int
  vendedorId             Int
  statusId               Int
  formaPagamentoId       Int?
  observacoesEmbalagem   String?
  observacoesFaturamento String?
  nomeVendedor           String?
  nomeComprador          String?
  valorFrete             Float     @default(0)
  tipoFrete              String?
  observacoesGerais      String?
  totalGeral             Float
  prazoEntrega           DateTime?
  ocCliente              String?
  ativo                  Boolean   @default(true)
  criadoEm               DateTime  @default(now())
  atualizadoEm           DateTime  @updatedAt

  empresa        Empresa         @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente        Cliente         @relation(fields: [clienteId], references: [id])
  vendedor       Vendedor        @relation(fields: [vendedorId], references: [id])
  status         Status          @relation(fields: [statusId], references: [id])
  formaPagamento FormaPagamento? @relation(fields: [formaPagamentoId], references: [id])
  orcamento      Orcamento?      @relation(fields: [orcamentoId], references: [id])
  itens          ItemPedido[]

  @@unique([empresaId, numero])
  @@index([empresaId])
  @@index([clienteId])
  @@index([vendedorId])
  @@index([statusId])
  @@index([criadoEm])
  @@index([ativo])
  @@index([orcamentoId])
  @@index([ocCliente])
  @@map("crm_pedidos")
}

model ItemPedido {
  id                Int     @id @default(autoincrement())
  pedidoId          Int
  produtoId         Int?
  descricao         String
  quantidade        Float // Float para suportar frações
  unidade           String
  precoUnitario     Float
  desconto          Float   @default(0)
  total             Float
  observacao        String?
  quantidadeCredito Float   @default(0)

  produto Produto? @relation(fields: [produtoId], references: [id], onDelete: SetNull)
  pedido  Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  @@index([pedidoId])
  @@index([produtoId])
  @@map("crm_itens_pedido")
}

model ItemExclusivoCliente {
  id        Int     @id @default(autoincrement())
  clienteId Int
  nome      String
  descricao String?
  preco     Float   @default(0)

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId])
  @@map("crm_itens_exclusivos_clientes")
}

// ─────────────────────────────────────────────
// CRÉDITO
// ─────────────────────────────────────────────

model MovimentacaoCredito {
  id          Int             @id @default(autoincrement())
  empresaId   Int
  clienteId   Int
  tipo        TipoCredito
  operacao    OperacaoCredito
  quantidade  Float
  descricao   String?
  orcamentoId Int?
  criadoEm    DateTime        @default(now())

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([empresaId])
  @@index([clienteId])
  @@index([criadoEm])
  @@index([tipo])
  @@index([operacao])
  @@map("crm_movimentacoes_credito")
}

// ─────────────────────────────────────────────
// AI
// ─────────────────────────────────────────────

model AIConfig {
  id           Int      @id @default(autoincrement())
  empresaId    Int      @unique // isolado por empresa
  provider     String   @default("gemini-flash")
  apiKey       String   @default("")
  systemPrompt String   @default("Você é o assistente inteligente, focado em ajudar na gestão de orçamentos, pedidos e produtos.")
  monthlyLimit Int      @default(500)
  updatedAt    DateTime @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@map("crm_ai_configs")
}

model AIChatMessage {
  id        Int      @id @default(autoincrement())
  userId    Int
  role      String
  content   String
  toolCalls Json?
  imageUrl  String? // renomeado de "image" para clareza
  timestamp DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
  @@map("crm_ai_chat_messages")
}

model AIUsage {
  id         Int      @id @default(autoincrement())
  empresaId  Int // isolado por empresa
  monthYear  String
  count      Int      @default(0)
  tokensUsed Int      @default(0)
  updatedAt  DateTime @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, monthYear])
  @@index([empresaId])
  @@map("crm_ai_usage")
}

model AIAprendizado {
  id        Int      @id @default(autoincrement())
  empresaId Int // isolado por empresa
  topico    String
  licao     String
  confianca Float    @default(1.0)
  criadoEm  DateTime @default(now())
  updatedAt DateTime @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId, topico])
  @@index([topico])
  @@map("crm_ai_aprendizados")
}

model AISugestao {
  id           Int            @id @default(autoincrement())
  empresaId    Int // isolado por empresa
  clienteId    Int?
  tipo         String
  dados        Json
  raciocinio   String?
  status       StatusSugestao @default(PENDENTE)
  feedback     String?
  criadoEm     DateTime       @default(now())
  processadoEm DateTime?

  empresa Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  @@index([empresaId])
  @@index([status])
  @@index([tipo])
  @@index([clienteId])
  @@map("crm_ai_sugestoes")
}

// ─────────────────────────────────────────────
// CRM - LEADS E FUNIL DE VENDAS
// ─────────────────────────────────────────────

model OrigemLead {
  id        Int      @id @default(autoincrement())
  empresaId Int
  nome      String
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())
  updatedAt DateTime @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  leads   Lead[]

  @@unique([empresaId, nome])
  @@index([empresaId])
  @@map("crm_origem_lead")
}

model FunilStatus {
  id        Int      @id @default(autoincrement())
  empresaId Int
  nome      String
  cor       String
  ordem     Int
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())
  updatedAt DateTime @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  leads   Lead[]

  @@unique([empresaId, ordem])
  @@unique([empresaId, nome])
  @@index([empresaId])
  @@map("crm_funil_status")
}

model Lead {
  id             Int       @id @default(autoincrement())
  empresaId      Int
  nome           String
  email          String?
  telefone       String?
  cep            String?
  cargo          String?
  nomeEmpresa    String?
  valorEstimado  Float     @default(0)
  temperatura    String?   // Frio, Morno, Quente
  observacoes    String?
  origemId       Int?
  statusId       Int?
  vendedorId     Int?
  clienteId      Int?
  ativo          Boolean   @default(true)
  dataConversao  DateTime?
  criadoEm       DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  empresa  Empresa      @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  origem   OrigemLead?  @relation(fields: [origemId], references: [id], onDelete: SetNull)
  status   FunilStatus? @relation(fields: [statusId], references: [id], onDelete: SetNull)
  vendedor Vendedor?    @relation(fields: [vendedorId], references: [id], onDelete: SetNull)
  cliente  Cliente?     @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  @@index([empresaId])
  @@index([origemId])
  @@index([statusId])
  @@index([vendedorId])
  @@index([clienteId])
  @@index([ativo])
  @@map("crm_leads")
}

// ─────────────────────────────────────────────
// COMPRAS & PORTAL DE FORNECEDORES
// ─────────────────────────────────────────────

enum TipoArquivoImportacao {
  XLSX
  XLS
  CSV

  @@map("crm_tipo_arquivo_importacao")
}

enum CampoImportacaoFornecedor {
  CODIGO_FORNECEDOR
  EAN
  DESCRICAO
  PRECO
  ESTOQUE
  MULTIPLO
  EMBALAGEM
  OBSERVACAO
  LABORATORIO
  FORNECEDOR

  @@map("crm_campo_importacao_fornecedor")
}

enum StatusImportacao {
  RASCUNHO
  PROCESSANDO
  CONCLUIDA
  ERRO
  CANCELADA

  @@map("crm_status_importacao")
}

enum StatusImportacaoLinha {
  PENDENTE
  VALIDA
  ERRO
  IGNORADA
  VINCULADA

  @@map("crm_status_importacao_linha")
}

enum TipoMatchProduto {
  EAN
  CODIGO_FORNECEDOR
  NOME_NORMALIZADO
  MANUAL

  @@map("crm_tipo_match_produto")
}

enum FonteConsumoCompra {
  ITEM_PEDIDO
  MOVIMENTACAO_ESTOQUE

  @@map("crm_fonte_consumo_compra")
}

enum StatusSugestaoCompra {
  RASCUNHO
  GERADA
  APROVADA
  EM_COTACAO
  CONVERTIDA
  CANCELADA

  @@map("crm_status_sugestao_compra")
}

enum StatusCotacaoCompra {
  RASCUNHO
  ABERTA
  EM_RESPOSTA
  FECHADA
  CANCELADA

  @@map("crm_status_cotacao_compra")
}

enum StatusCotacaoFornecedor {
  PENDENTE
  VISUALIZADA
  RESPONDIDA
  BLOQUEADA
  EXPIRADA

  @@map("crm_status_cotacao_fornecedor")
}

enum StatusPedidoCompra {
  RASCUNHO
  ENVIADO
  CONFIRMADO
  RECEBIDO_PARCIAL
  RECEBIDO
  CANCELADO

  @@map("crm_status_pedido_compra")
}

enum AcaoAuditoriaCompra {
  IMPORTAR
  VINCULAR
  APROVAR_SUGESTAO
  ESCOLHER_VENCEDOR
  GERAR_PEDIDO
  RESPONDER_COTACAO

  @@map("crm_acao_auditoria_compra")
}

model FornecedorImportConfig {
  id               Int                   @id @default(autoincrement())
  empresaId        Int
  fornecedorId     Int                   @unique
  tipoArquivo      TipoArquivoImportacao @default(XLSX)
  nomeAba          String?
  linhaCabecalho   Int                   @default(1)
  linhaInicioDados Int                   @default(2)
  delimitadorCsv   String?
  encoding         String?               @default("utf-8")
  ativo            Boolean               @default(true)
  criadoEm         DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  criadoPorUserId  Int?

  empresa     Empresa                  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  fornecedor  Fornecedor               @relation(fields: [fornecedorId], references: [id], onDelete: Cascade)
  campos      FornecedorImportCampo[]
  importacoes FornecedorImportacao[]

  @@index([empresaId])
  @@map("crm_fornecedor_import_configs")
}

model FornecedorImportCampo {
  id            Int                       @id @default(autoincrement())
  configId      Int
  campo         CampoImportacaoFornecedor
  coluna        String
  obrigatorio   Boolean                   @default(false)
  transformacao String?

  config FornecedorImportConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@unique([configId, campo])
  @@map("crm_fornecedor_import_campos")
}

model FornecedorImportacao {
  id                 Int              @id @default(autoincrement())
  empresaId          Int
  fornecedorId       Int
  configId           Int?
  nomeArquivo        String
  hashArquivo        String?
  status             StatusImportacao @default(RASCUNHO)
  totalLinhas        Int              @default(0)
  linhasValidas      Int              @default(0)
  linhasErro         Int              @default(0)
  linhasVinculadas   Int              @default(0)
  mensagemErro       String?
  importadoPorUserId Int
  processadoEm       DateTime?
  criadoEm           DateTime         @default(now())

  empresa    Empresa                     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  fornecedor Fornecedor                  @relation(fields: [fornecedorId], references: [id], onDelete: Cascade)
  config     FornecedorImportConfig?     @relation(fields: [configId], references: [id], onDelete: SetNull)
  linhas     FornecedorImportacaoLinha[]

  @@index([empresaId, fornecedorId, criadoEm])
  @@index([status])
  @@map("crm_fornecedor_importacoes")
}

model FornecedorImportacaoLinha {
  id                Int                   @id @default(autoincrement())
  importacaoId      Int
  numeroLinha       Int
  status            StatusImportacaoLinha @default(PENDENTE)
  dadosOriginais    Json
  codigoFornecedor  String?
  ean               String?
  descricao         String?
  preco             Float?
  estoqueFornecedor Float?
  multiplo          Float?
  embalagem         String?
  observacao        String?
  laboratorio       String?
  produtoId         Int?
  erroMensagem      String?
  matchTipo         TipoMatchProduto?

  importacao  FornecedorImportacao @relation(fields: [importacaoId], references: [id], onDelete: Cascade)
  produto     Produto?             @relation(fields: [produtoId], references: [id], onDelete: SetNull)
  precoAtual  FornecedorPrecoAtual?

  @@unique([importacaoId, numeroLinha])
  @@index([importacaoId, status])
  @@index([ean])
  @@index([codigoFornecedor])
  @@map("crm_fornecedor_importacao_linhas")
}

model FornecedorProdutoMap {
  id                  Int              @id @default(autoincrement())
  empresaId           Int
  fornecedorId        Int
  produtoId           Int
  codigoFornecedor    String
  eanFornecedor       String?
  descricaoFornecedor String?
  matchTipo           TipoMatchProduto
  confirmadoManual    Boolean          @default(false)
  ativo               Boolean          @default(true)
  vinculadoPorUserId  Int?
  criadoEm            DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  empresa    Empresa    @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  fornecedor Fornecedor @relation(fields: [fornecedorId], references: [id], onDelete: Cascade)
  produto    Produto    @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@unique([fornecedorId, codigoFornecedor])
  @@index([empresaId, produtoId])
  @@index([fornecedorId, eanFornecedor])
  @@map("crm_fornecedor_produto_map")
}

model FornecedorPrecoAtual {
  id                Int      @id @default(autoincrement())
  empresaId         Int
  fornecedorId      Int
  produtoId         Int
  preco             Float
  estoqueFornecedor Float?
  multiplo          Float?
  embalagem         String?
  laboratorio       String?
  importacaoLinhaId Int?     @unique
  vigenteDesde      DateTime @default(now())
  atualizadoEm      DateTime @updatedAt

  empresa     Empresa                    @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  fornecedor  Fornecedor                 @relation(fields: [fornecedorId], references: [id], onDelete: Cascade)
  produto     Produto                     @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  linhaOrigem FornecedorImportacaoLinha? @relation(fields: [importacaoLinhaId], references: [id], onDelete: SetNull)

  @@unique([fornecedorId, produtoId])
  @@index([empresaId, produtoId])
  @@map("crm_fornecedor_preco_atual")
}

model FornecedorPrecoHistorico {
  id                Int      @id @default(autoincrement())
  empresaId         Int
  fornecedorId      Int
  produtoId         Int
  preco             Float
  importacaoId      Int?
  importacaoLinhaId Int?
  registradoEm      DateTime @default(now())

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  produto Produto @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@index([fornecedorId, produtoId, registradoEm])
  @@index([produtoId, registradoEm])
  @@map("crm_fornecedor_preco_historico")
}

model CompraConfigEmpresa {
  id                   Int                @id @default(autoincrement())
  empresaId            Int                @unique
  multiplicadorConsumo Float              @default(3)
  diasJanelaConsumo    Int                @default(90)
  fonteConsumo         FonteConsumoCompra @default(MOVIMENTACAO_ESTOQUE)
  updatedAt            DateTime           @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@map("crm_compra_config_empresa")
}

model SugestaoCompra {
  id                Int                  @id @default(autoincrement())
  empresaId         Int
  numero            String
  status            StatusSugestaoCompra @default(RASCUNHO)
  geradaPorUserId   Int
  aprovadaPorUserId Int?
  observacoes       String?
  criadoEm          DateTime             @default(now())
  atualizadoEm      DateTime             @updatedAt

  empresa Empresa              @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  itens   SugestaoCompraItem[]
  cotacao CotacaoCompra?

  @@unique([empresaId, numero])
  @@map("crm_sugestao_compra")
}

model SugestaoCompraItem {
  id                 Int     @id @default(autoincrement())
  sugestaoId         Int
  produtoId          Int
  estoqueAtual       Float
  mediaConsumo       Float
  quantidadeSugerida Float
  quantidadeAjustada Float?
  incluir            Boolean @default(true)

  sugestao SugestaoCompra @relation(fields: [sugestaoId], references: [id], onDelete: Cascade)
  produto  Produto        @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@unique([sugestaoId, produtoId])
  @@map("crm_sugestao_compra_itens")
}

model CotacaoCompra {
  id              Int                 @id @default(autoincrement())
  empresaId       Int
  sugestaoId      Int?                @unique
  numero          String
  titulo          String?
  status          StatusCotacaoCompra @default(RASCUNHO)
  prazoResposta   DateTime?
  criadoPorUserId Int
  fechadaEm       DateTime?
  criadoEm        DateTime            @default(now())
  atualizadoEm    DateTime            @updatedAt

  empresa       Empresa                   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  sugestao      SugestaoCompra?           @relation(fields: [sugestaoId], references: [id], onDelete: SetNull)
  itens         CotacaoCompraItem[]
  fornecedores  CotacaoCompraFornecedor[]
  escolhas      CotacaoCompraEscolha[]
  pedidosCompra PedidoCompra[]

  @@unique([empresaId, numero])
  @@map("crm_cotacao_compra")
}

model CotacaoCompraItem {
  id         Int     @id @default(autoincrement())
  cotacaoId  Int
  produtoId  Int
  quantidade Float
  descricao  String?
  unidade    String  @default("UN")

  cotacao   CotacaoCompra               @relation(fields: [cotacaoId], references: [id], onDelete: Cascade)
  produto   Produto                     @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  respostas CotacaoCompraRespostaItem[]
  escolha   CotacaoCompraEscolha?

  @@unique([cotacaoId, produtoId])
  @@map("crm_cotacao_compra_itens")
}

model CotacaoCompraFornecedor {
  id            Int                     @id @default(autoincrement())
  cotacaoId     Int
  fornecedorId  Int
  tokenHash     String                  @unique
  tokenPrefix   String
  status        StatusCotacaoFornecedor @default(PENDENTE)
  emailConvite  String?
  respondidoEm  DateTime?
  bloqueadoEm   DateTime?
  visualizadoEm DateTime?
  criadoEm      DateTime                @default(now())

  cotacao    CotacaoCompra               @relation(fields: [cotacaoId], references: [id], onDelete: Cascade)
  fornecedor Fornecedor                  @relation(fields: [fornecedorId], references: [id], onDelete: Cascade)
  respostas  CotacaoCompraRespostaItem[]

  @@unique([cotacaoId, fornecedorId])
  @@map("crm_cotacao_compra_fornecedores")
}

model CotacaoCompraRespostaItem {
  id                   Int      @id @default(autoincrement())
  cotacaoFornecedorId  Int
  cotacaoItemId        Int
  precoUnitario        Float?
  prazoEntregaDias     Int?
  quantidadeDisponivel Float?
  observacao           String?
  bloqueado            Boolean  @default(false)
  respondidoEm         DateTime @default(now())

  cotacaoFornecedor CotacaoCompraFornecedor @relation(fields: [cotacaoFornecedorId], references: [id], onDelete: Cascade)
  cotacaoItem       CotacaoCompraItem       @relation(fields: [cotacaoItemId], references: [id], onDelete: Cascade)
  escolha           CotacaoCompraEscolha?

  @@unique([cotacaoFornecedorId, cotacaoItemId])
  @@map("crm_cotacao_compra_resposta_itens")
}

model CotacaoCompraEscolha {
  id                 Int      @id @default(autoincrement())
  cotacaoId          Int
  cotacaoItemId      Int      @unique
  fornecedorId       Int
  respostaItemId     Int      @unique
  escolhidoPorUserId Int
  motivo             String?
  criadoEm           DateTime @default(now())

  cotacao      CotacaoCompra             @relation(fields: [cotacaoId], references: [id], onDelete: Cascade)
  cotacaoItem  CotacaoCompraItem         @relation(fields: [cotacaoItemId], references: [id], onDelete: Cascade)
  fornecedor   Fornecedor                @relation(fields: [fornecedorId], references: [id], onDelete: Cascade)
  respostaItem CotacaoCompraRespostaItem @relation(fields: [respostaItemId], references: [id], onDelete: Cascade)

  @@map("crm_cotacao_compra_escolhas")
}

model PedidoCompra {
  id              Int                @id @default(autoincrement())
  empresaId       Int
  fornecedorId    Int
  cotacaoId       Int?
  numero          String
  status          StatusPedidoCompra @default(RASCUNHO)
  totalGeral      Float              @default(0)
  observacoes     String?
  geradoPorUserId Int
  enviadoEm       DateTime?
  criadoEm        DateTime           @default(now())
  atualizadoEm    DateTime           @updatedAt

  empresa    Empresa            @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  fornecedor Fornecedor         @relation(fields: [fornecedorId], references: [id], onDelete: Cascade)
  cotacao    CotacaoCompra?     @relation(fields: [cotacaoId], references: [id], onDelete: SetNull)
  itens      ItemPedidoCompra[]

  @@unique([empresaId, numero])
  @@index([fornecedorId])
  @@map("crm_pedidos_compra")
}

model ItemPedidoCompra {
  id             Int     @id @default(autoincrement())
  pedidoCompraId Int
  produtoId      Int
  cotacaoItemId  Int?
  escolhaId      Int?
  descricao      String
  quantidade     Float
  unidade        String  @default("UN")
  precoUnitario  Float
  total          Float
  observacao     String?

  pedidoCompra PedidoCompra @relation(fields: [pedidoCompraId], references: [id], onDelete: Cascade)
  produto      Produto      @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@index([pedidoCompraId])
  @@map("crm_itens_pedido_compra")
}

model CompraAuditoria {
  id         Int                 @id @default(autoincrement())
  empresaId  Int
  userId     Int?
  acao       AcaoAuditoriaCompra
  entidade   String
  entidadeId Int
  detalhes   Json?
  criadoEm   DateTime            @default(now())

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([empresaId, entidade, entidadeId])
  @@index([criadoEm])
  @@map("crm_compra_auditoria")
}
