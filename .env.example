# Modelo de variáveis de ambiente — copie para .env (local) e preencha.
# NÃO coloque segredos reais aqui. Este arquivo é versionado; .env não é.

# Banco de dados (Neon Postgres). As duas apontam para a mesma URL.
DB_URL_OFFICIAL="postgresql://USUARIO:SENHA@HOST.neon.tech/BANCO?sslmode=require&channel_binding=require"
DATABASE_URL="postgresql://USUARIO:SENHA@HOST.neon.tech/BANCO?sslmode=require&channel_binding=require"

# Engine do Prisma
PRISMA_CLIENT_ENGINE_TYPE=library

# Segredo para assinar o cookie de sessão (HMAC). Gere um novo: openssl rand -hex 32
SESSION_SECRET="troque-por-um-valor-aleatorio-forte"

# Bluesoft Cosmos — consulta de EAN/GTIN (opcional). Fica em .env.local.
# COSMOS_TOKEN="seu-token-cosmos"

# Cloudflare R2 — storage de arquivos (logos, e futuramente PDFs de edital).
# Sem estas vars, o upload de logo cai para base64 no banco (modo interino).
# R2_ACCOUNT_ID="seu-account-id-cloudflare"
# R2_ACCESS_KEY_ID="sua-access-key-r2"
# R2_SECRET_ACCESS_KEY="sua-secret-key-r2"
# R2_BUCKET="nome-do-bucket"
# R2_PUBLIC_URL="https://pub-xxxx.r2.dev"  # URL pública do bucket (ou domínio próprio)

# Chamados → endpoint dos desenvolvedores (a configurar quando definido).
# CHAMADO_DEV_ENDPOINT="https://..."
# CHAMADO_DEV_TOKEN="..."
